---
import { getCollection } from 'astro:content';
import ParcheLayout from '../layouts/ParcheLayout.astro';
import { render } from 'astro:content';

const parches = await getCollection('parches');
const sorted = parches.sort((a, b) => b.data.week - a.data.week);
const latest = sorted[0];

if (!latest) {
  throw new Error('No hay parches disponibles');
}

const { Content } = await render(latest);

const versions = sorted.map((p, i) => ({
  id: p.id,
  version: p.data.version,
  date: p.data.date.toLocaleDateString('es-CL', { day: 'numeric', month: 'short', year: 'numeric' }),
  isLatest: i === 0,
}));

const formattedDate = latest.data.date.toLocaleDateString('es-CL', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<ParcheLayout
  title={`${latest.data.version} — ChileOnline`}
  version={latest.data.version}
  subtitle={latest.data.subtitle}
  date={formattedDate}
  status={latest.data.status}
  versions={versions}
  currentId={latest.id}
>
  <Content />
</ParcheLayout>
