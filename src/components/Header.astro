---
---
<header class="site-header">
  <div class="header-inner">
    <div class="header-brand">
      <div class="logo-icon">🎮</div>
      <div class="brand-text">
        <h1 class="site-title">CHILEONLINE</h1>
        <span class="site-subtitle">La Actualización Nacional</span>
      </div>
    </div>
    <div class="header-meta">
      <div class="server-status">
        <span class="status-dot"></span>
        <span class="status-text">SERVIDOR ACTIVO</span>
      </div>
      <div class="header-links">
        <a href="/" class="nav-link">Último Parche</a>
        <a href="#archive" class="nav-link">Archivo</a>
      </div>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: linear-gradient(180deg, var(--bg-header) 0%, rgba(8, 12, 22, 0.95) 100%);
    border-bottom: 1px solid var(--border-gold);
    backdrop-filter: blur(12px);
  }

  .header-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: var(--header-height);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .header-brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .logo-icon {
    font-size: 2rem;
    filter: drop-shadow(0 0 8px var(--gold-glow));
  }

  .site-title {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: var(--gold);
    text-shadow: 0 0 20px var(--gold-glow);
    line-height: 1;
  }

  .site-subtitle {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .header-meta {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .server-status {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0.75rem;
    background: rgba(34, 197, 94, 0.1);
    border: 1px solid rgba(34, 197, 94, 0.3);
    border-radius: 999px;
  }

  .status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--green);
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; box-shadow: 0 0 4px var(--green); }
    50% { opacity: 0.5; box-shadow: 0 0 12px var(--green); }
  }

  .status-text {
    font-family: var(--font-heading);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    color: var(--green);
  }

  .header-links {
    display: flex;
    gap: 1rem;
  }

  .nav-link {
    font-family: var(--font-heading);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: var(--text-secondary);
    transition: color 0.2s ease;
  }

  .nav-link:hover {
    color: var(--gold);
  }

  @media (max-width: 768px) {
    .header-inner {
      flex-direction: column;
      height: auto;
      padding: 0.75rem 1rem;
      gap: 0.5rem;
    }

    .header-meta {
      width: 100%;
      justify-content: space-between;
    }

    .site-title {
      font-size: 1.3rem;
    }
  }
</style>
