---
interface Props {
  type: 'buff' | 'nerf' | 'new' | 'bugfix' | 'hotfix' | 'removed';
}

const { type } = Astro.props;

const badgeConfig = {
  buff: { label: 'BUFF', color: 'var(--green)', bg: 'rgba(34, 197, 94, 0.15)' },
  nerf: { label: 'NERF', color: 'var(--red)', bg: 'rgba(239, 68, 68, 0.15)' },
  new: { label: 'NEW', color: 'var(--purple)', bg: 'rgba(168, 85, 247, 0.15)' },
  bugfix: { label: 'BUG FIX', color: 'var(--orange)', bg: 'rgba(249, 115, 22, 0.15)' },
  hotfix: { label: 'HOTFIX', color: 'var(--red)', bg: 'rgba(239, 68, 68, 0.2)' },
  removed: { label: 'REMOVED', color: 'var(--text-muted)', bg: 'rgba(100, 116, 139, 0.15)' },
};

const config = badgeConfig[type];
---

<span class="patch-badge" style={`color: ${config.color}; background: ${config.bg}; border-color: ${config.color};`}>
  {config.label}
</span>

<style>
  .patch-badge {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    padding: 0.15rem 0.5rem;
    border-radius: 3px;
    border: 1px solid;
    text-transform: uppercase;
    vertical-align: middle;
    line-height: 1.4;
  }
</style>
