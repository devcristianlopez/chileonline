---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';
import Footer from '../components/Footer.astro';

interface Version {
  id: string;
  version: string;
  date: string;
  isLatest?: boolean;
}

interface Props {
  title: string;
  version: string;
  subtitle: string;
  date: string;
  status: string;
  versions: Version[];
  currentId: string;
}

const { title, version, subtitle, date, status, versions, currentId } = Astro.props;

const statusConfig: Record<string, { label: string; color: string }> = {
  LIVE: { label: 'EN VIVO', color: 'var(--green)' },
  PENDIENTE: { label: 'PENDIENTE', color: 'var(--orange)' },
  DEPRECATED: { label: 'OBSOLETO', color: 'var(--text-muted)' },
};

const currentStatus = statusConfig[status] || statusConfig.LIVE;
---

<BaseLayout title={title}>
  <Header />

  <div class="parche-layout">
    <Sidebar versions={versions} currentId={currentId} />

    <main class="parche-main">
      <div class="parche-hero">
        <div class="hero-badge" style={`color: ${currentStatus.color}; border-color: ${currentStatus.color};`}>
          {currentStatus.label}
        </div>
        <h1 class="hero-version">{version}</h1>
        <p class="hero-subtitle">{subtitle}</p>
        <div class="hero-meta">
          <span class="meta-item">
            <span class="meta-icon">📅</span>
            Publicado: {date}
          </span>
          <span class="meta-item">
            <span class="meta-icon">⏱️</span>
            Tiempo de lectura: ~5 min
          </span>
        </div>
        <div class="hero-divider"></div>
      </div>

      <div class="parche-content">
        <slot />
      </div>
    </main>
  </div>

  <Footer />
</BaseLayout>

<style>
  .parche-layout {
    display: flex;
    min-height: calc(100vh - var(--header-height));
  }

  .parche-main {
    flex: 1;
    min-width: 0;
    padding: 2rem;
    max-width: calc(100% - var(--sidebar-width));
  }

  .parche-hero {
    max-width: var(--content-max-width);
    margin: 0 auto 2.5rem;
    text-align: center;
    padding: 2rem 0;
  }

  .hero-badge {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    padding: 0.3rem 1rem;
    border: 1px solid;
    border-radius: 999px;
    margin-bottom: 1rem;
    text-transform: uppercase;
  }

  .hero-version {
    font-family: var(--font-heading);
    font-size: 3rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--gold);
    text-shadow: 0 0 30px var(--gold-glow);
    margin-bottom: 0.5rem;
  }

  .hero-subtitle {
    font-size: 1.1rem;
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
  }

  .hero-meta {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .meta-item {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .meta-icon {
    font-size: 0.9rem;
  }

  .hero-divider {
    width: 100px;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
    margin: 1.5rem auto 0;
  }

  .parche-content {
    max-width: var(--content-max-width);
    margin: 0 auto;
  }

  @media (max-width: 1024px) {
    .parche-layout {
      flex-direction: column;
    }

    .parche-main {
      max-width: 100%;
      padding: 1.5rem 1rem;
    }

    .hero-version {
      font-size: 2rem;
    }
  }
</style>
